class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int>hash;
        for(int i=0;i<nums.size();i++){
            int num=target-nums[i];
            auto ietrator=hash.find(num);
            if(ietrator!=hash.end()){
                return {ietrator->second,i};
            }else{
                hash.insert({nums[i],i});
            }
        }
        return {-1,-1};
    }
};
/* Notes:
used unordered_map for immeditae lookup and to avoid using doule for loops to match a number with all other numbers in the vector repeatedly.
*/
